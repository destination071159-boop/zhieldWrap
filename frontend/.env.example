# Optional — defaults to public Sepolia RPC
VITE_SEPOLIA_RPC=https://rpc.sepolia.org

# Optional — chain ID (default: 11155111 = Sepolia)
VITE_CHAIN_ID=11155111

# ── Our deployed contracts (fill in after running: npx hardhat run scripts/deploy.ts) ──

# ZKVerifier.sol — Groth16 proof verifier
VITE_ZK_VERIFIER_ADDRESS=0x62dBF2724FA845A00712FD992736289FA6a72F6d

# PrivacyPool.sol — FhEVM encrypted deposits + ZK withdrawals
VITE_PRIVACY_POOL_ADDRESS=0x6Cb4dA4E8712866ED8B98c753DC396D94281C36E

# CrossSwapRouter.sol — cross-pair swap routing
VITE_CROSS_SWAP_ROUTER_ADDRESS=0x65422Cde6Af545d84184a55f6b6963B75812dcc2

# ConfidentialSwapPool.sol — direct FHE cToken↔cToken swap
VITE_CONFIDENTIAL_SWAP_POOL_ADDRESS=0x88D2dDC39Cde7cf0195f7713784D8e60f857Fe0a

# ── Zama FhEVM ──

# NOTE: No VITE_FHEVM_GATEWAY needed.
# The Zama Gateway is a separate chain — @zama-fhe/react-sdk connects to it automatically.
# See: https://docs.zama.org/protocol/protocol/overview/gateway
